*.db
*.db-wal
*.db-shm
 
# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
venv/
.venv/
env/
*.egg-info/
dist/
build/
 
# ── Системное ────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
 